# === Required ===

# Long random string (32+ chars) used to sign session tokens.
# Generate one with: openssl rand -hex 32
SESSION_SECRET=

# Public URL of the deployed app (used in email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Initial admin account bootstrap ===
# On first login/register after deploy, if no admin account exists yet,
# one is created from these two vars (password is hashed, never stored in plain text).
# Set these once, deploy, log in as admin, then you can remove them.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# === Database (Supabase) ===
# If unset, falls back to a local JSON file at src/data/local_db.json (dev only).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service-role key (Supabase dashboard > Settings > API).
# Required for production once Row Level Security is enabled (see
# supabase/migrations) — the app uses this key server-side only, and it
# bypasses RLS. Never expose it with a NEXT_PUBLIC_ prefix or to the client.
SUPABASE_SERVICE_ROLE_KEY=

# === AI Travel Assistant (Groq) ===
# Get a key from https://console.groq.com. If unset, the assistant widget
# still renders but replies with a "not configured" message pointing to
# WhatsApp/email instead.
GROQ_API_KEY=
# Optional override. Defaults to openai/gpt-oss-120b (Groq's recommended
# tool-use model after the 2026 deprecation of llama-3.3-70b-versatile).
GROQ_MODEL=

# === Email (Resend) ===
# If unset, emails are logged to the console instead of sent.
RESEND_API_KEY=

# === File storage (Cloudflare R2) ===
# If unset, falls back to local disk storage under public/uploads (dev only).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_CUSTOM_DOMAIN=
